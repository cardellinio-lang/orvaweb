generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PageView {
  id    Int      @id @default(autoincrement())
  date  DateTime @default(now())
  path  String   @default("/")
  count Int      @default(1)
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  price       Int
  oldPrice    Int?
  images      String      @default("[]")
  description String      @default("")
  color       String      @default("#000000")
  category    String      @default("")
  sku         String?
  stock       Int         @default(1)
  active      Boolean     @default(true)
  tierEnabled Boolean     @default(false)
  tierQty     Int?
  tierPrice   Int?
  tierMessage String?
  tierGift    String?
  createdAt   DateTime    @default(now())
  orders      OrderItem[]
}

model Wilaya {
  id          Int       @id
  name        String
  price       Int
  priceOffice Int       @default(0)
  communes    Commune[]
}

model Commune {
  id       Int    @id @default(autoincrement())
  name     String
  wilayaId Int
  wilaya   Wilaya @relation(fields: [wilayaId], references: [id])
}

model Order {
  id        String      @id @default(cuid())
  number    String      @unique
  customer  String
  phone     String
  wilayaId  Int
  communeId Int
  address   String
  total     Int
  delivery  Int
  deliveryType String      @default("home")
  status    String      @default("pending")
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Int
  quantity  Int
}
